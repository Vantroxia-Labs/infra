# ═══════════════════════════════════════════════════════════════════════════
# AegisRemit — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# Domain
DOMAIN=aegisremit.ng

# Docker image tag (set by CI/CD)
IMAGE_TAG=latest

# ── Let's Encrypt ──────────────────────────────────────────────────────────
ACME_EMAIL=davidgodswill@gmail.com

# ── Cloudflare (DNS challenge for wildcard SSL) ───────────────────────────
# Create API token at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone > DNS > Edit (scoped to aegisremit.ng zone)
CF_DNS_API_TOKEN=

# ── Traefik Dashboard ─────────────────────────────────────────────────────
# Generate with: htpasswd -nB admin
# Format: user:hashed_password (escape $ as $$ in docker-compose)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$...

# ── Aiven Cloud PostgreSQL ─────────────────────────────────────────────────
# Connection string from Aiven console (Service URI format)
AIVEN_CONNECTION_STRING=Host=your-host.aivencloud.com;Port=12345;Database=aegisremit;Username=avnadmin;Password=YOUR_AIVEN_PASSWORD;SslMode=Require;Trust Server Certificate=true

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=AEGIS_$TR0NG_P@$$W0RD_1

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=aegisremit
RABBITMQ_PASSWORD=AEGIS_$TR0NG_P@$$W0RD_2

# ── MinIO (Object Storage) ────────────────────────────────────────────────
MINIO_ROOT_USER=aegisremit
MINIO_ROOT_PASSWORD=AEGIS_$TR0NG_P@$$W0RD_3

# ── JWT (consumed by Portal.API, ERP.API, SFTP.API) ───────────────────────
# Generate secret with: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
JWT_ISSUER=https://api.aegisremit.ng
JWT_AUDIENCE=aegisremit

# ── Payload encryption (sensitive request body encryption middleware) ─────
# Key must be 32 bytes (AES-256). Generate with: openssl rand -base64 32
# IV must be 16 bytes. Generate with: openssl rand -base64 16
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_KEY
ENCRYPTION_IV=CHANGE_ME_16_BYTE_BASE64_IV
