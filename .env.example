# ═══════════════════════════════════════════════════════════════════════════
# AegisRemit — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Used by:
#   docker-compose.yml      — Infrastructure services (Traefik, Redis, RabbitMQ, MinIO, SFTPGo, OTel)
#   docker-compose.apps.yml — Application services (Portal API, ERP API, SFTP API, Admin)
# ═══════════════════════════════════════════════════════════════════════════

# Domain
DOMAIN=aegisremit.ng

# Docker image tag (set by CI/CD)
IMAGE_TAG=latest

# ── Let's Encrypt ──────────────────────────────────────────────────────────
ACME_EMAIL=davidgodswill@gmail.com

# ── Cloudflare (DNS challenge for wildcard SSL) ───────────────────────────
# Create API token at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone > DNS > Edit (scoped to aegisremit.ng zone)
CF_DNS_API_TOKEN=

# ── Traefik Dashboard ─────────────────────────────────────────────────────
# Generate with: htpasswd -nB admin
# Format: user:hashed_password (escape $ as $$ in docker-compose)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$CHANGE_ME

# ── PostgreSQL (self-hosted in infra stack) ────────────────────────────────
# Runs as the `postgres` service (container: aegisremit-postgres) on the
# internal network. Generate a strong password with: openssl rand -base64 24
POSTGRES_DB=aegisremit
POSTGRES_USER=aegisremit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
# Connection string consumed by Portal.API, ERP.API, SFTP.API and the migrator.
# Host is the postgres container name; keep DB/User/Password in sync with the 3 vars above.
DB_CONNECTION_STRING=Host=aegisremit-postgres;Port=5432;Database=aegisremit;Username=aegisremit;Password=CHANGE_ME_STRONG_POSTGRES_PASSWORD;Pooling=true

# ── Aiven Cloud PostgreSQL (fallback / optional) ───────────────────────────
# Not used by default. To switch back to Aiven, set the apps'
# ConnectionStrings__DefaultConnection to ${AIVEN_CONNECTION_STRING} in apps/docker-compose.yml.
# AIVEN_CONNECTION_STRING=Host=your-host.aivencloud.com;Port=12345;Database=aegisremit;Username=avnadmin;Password=YOUR_AIVEN_PASSWORD;SslMode=Require;Trust Server Certificate=true

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=aegisremit
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBITMQ_PASSWORD

# ── MinIO (Object Storage) ────────────────────────────────────────────────
MINIO_ROOT_USER=aegisremit
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD

# ── SFTPGo (SFTP Server — Infrastructure) ─────────────────────────────────
# Default admin credentials for first-time setup (change after first login)
SFTPGO_ADMIN_USER=admin
SFTPGO_ADMIN_PASSWORD=CHANGE_ME_STRONG_SFTPGO_PASSWORD
# API key for programmatic access (used by sftp-api in docker-compose.apps.yml)
# Generate after first login: POST /api/v2/apikeys with admin JWT
# See: Remit/get-sftpgo-apikey.ps1
SFTPGO_API_KEY=CHANGE_ME_GENERATE_AFTER_FIRST_LOGIN

# ── JWT (consumed by Portal.API, ERP.API, SFTP.API) ───────────────────────
# Generate secret with: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
JWT_ISSUER=https://api.aegisremit.ng
JWT_AUDIENCE=aegisremit

# ── Internal Encryption (database records & access tokens) ────────────────────
# Key: exactly 32 UTF-8 characters (AES-256 = 256 bits = 32 bytes)
# IV:  exactly 16 UTF-8 characters (AES block size = 128 bits = 16 bytes)
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_32_CHARACTER_PLAIN_TEXT
# Generate with: openssl rand -hex 8
ENCRYPTION_IV=CHANGE_ME_16_CHARACTER_PLAIN_TEXT

# ── Payload encryption (sensitive request body encryption middleware) ─────────
# Key must be 32 bytes (AES-256), Base64-encoded. Generate with: openssl rand -base64 32
PAYLOAD_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
