# Copy to .env, fill in, then: chmod 600 .env
BASE_DOMAIN=vantroxialabs.com

# PostgreSQL superuser (admin only — every app gets its own role)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=

# Redis (shared instance; apps use DB indexes 0,1,2…)
REDIS_PASSWORD=

# RabbitMQ admin (management UI at mq.<BASE_DOMAIN>, IP-restricted)
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASSWORD=

# MinIO root (console at minio.<BASE_DOMAIN>, S3 at s3.<BASE_DOMAIN>)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# OpenObserve — self-hosted logs/metrics/traces (UI at logs.<BASE_DOMAIN>)
# OPENOBSERVE_OTLP_AUTH = base64 of "EMAIL:PASSWORD" for the OTEL collector, e.g.:
#   echo -n 'you@example.com:<password>' | base64 -w0
OPENOBSERVE_EMAIL=
OPENOBSERVE_PASSWORD=
OPENOBSERVE_OTLP_AUTH=
