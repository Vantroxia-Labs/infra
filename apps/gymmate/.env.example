# Copy to .env on the VPS, fill in, chmod 600 .env
# GymMateHub backend (Spring Boot). RabbitMQ is NOT used.
BASE_DOMAIN=vantroxialabs.com
TAG=latest

# ── PostgreSQL (role/db created by create-app-db.sh gymmate) ──
GYMMATE_DB_PASSWORD=

# ── Redis (MUST equal REDIS_PASSWORD in infra/.env) ──
REDIS_PASSWORD=

# ── JWT (required — generate with: openssl rand -base64 48) ──
GYMMATE_JWT_SECRET=
GYMMATE_JWT_EXPIRATION=86400000
GYMMATE_JWT_REFRESH_EXPIRATION=604800000

# ── CORS / Frontend (React app) ──
GYMMATE_CORS_ALLOWED_ORIGINS=https://gymmate.vantroxialabs.com
GYMMATE_FRONTEND_URL=https://gymmate.vantroxialabs.com

# ── Bootstrap admin (optional) ──
GYMMATE_ADMIN_EMAIL=
GYMMATE_ADMIN_PASSWORD=

# ── SMTP (optional; leave blank for first boot) ──
GYMMATE_MAIL_HOST=
GYMMATE_MAIL_PORT=587
GYMMATE_MAIL_PASSWORD=

# ── Stripe (optional; leave blank for first boot) ──
GYMMATE_STRIPE_API_KEY=
GYMMATE_STRIPE_WEBHOOK_SECRET=
GYMMATE_STRIPE_CONNECT_WEBHOOK_SECRET=
