# Copy to .env, fill in, chmod 600 .env
AEGISREMIT_DB_PASSWORD=
AEGISREMIT_MQ_PASSWORD=
REDIS_PASSWORD=          # same value as infra/.env
# AES key/IV for EncryptionService — Key MUST be 32 chars, Iv MUST be 16 chars.
# Generate: openssl rand -hex 16  (key) / openssl rand -hex 8  (iv)
AEGISREMIT_ENCRYPTION_KEY=
AEGISREMIT_ENCRYPTION_IV=
# JWT signing key — generate: openssl rand -hex 32
AEGISREMIT_JWT_SECRET=
# ERP validates these on startup — replace with the real integration base URLs.
AEGISREMIT_FIRS_BASE_URL=https://einvoice.firs.gov.ng
AEGISREMIT_INTERSWITCH_BASE_URL=https://saztaxpayer.interswitchng.com
# Full connection string used by the migrator step in the deploy workflow.
# Mirror the DB password above.
DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=aegisremit_db;Username=aegisremit;Password=
TAG_PORTAL=latest
TAG_ERP=latest
