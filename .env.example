# ═══════════════════════════════════════════════════════════════════════════
# AegisRemit — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Used by:
#   docker-compose.yml      — Infrastructure services (Traefik, Redis, RabbitMQ, MinIO, SFTPGo, OTel)
#   docker-compose.apps.yml — Application services (Portal API, ERP API, SFTP API, Admin)
# ═══════════════════════════════════════════════════════════════════════════

# =====================================================================
# Default app password
# =====================================================================
LOCAL_AUTH=admin:Change_Me #  - plain pass
LOCAL_ADMIN=aegisremit

# Domain
DOMAIN=aegisremit.ng

# Docker image tag (set by CI/CD)
IMAGE_TAG=latest

# ── Let's Encrypt ──────────────────────────────────────────────────────────
ACME_EMAIL=davidgodswill@gmail.com

# ── Cloudflare (DNS challenge for wildcard SSL) ───────────────────────────
# Create API token at: https://dash.cloudflare.com/profile/api-tokens
# Permissions: Zone > DNS > Edit (scoped to aegisremit.ng zone)
CF_DNS_API_TOKEN=

# ── Traefik Dashboard ─────────────────────────────────────────────────────
# Use the local auth password for Traefik dashboard as well (same credentials for all services in local dev)
TRAEFIK_DASHBOARD_AUTH=${LOCAL_AUTH}

# ── Aiven Cloud PostgreSQL ─────────────────────────────────────────────────
# Connection string from Aiven console (Service URI format)
AIVEN_CONNECTION_STRING=Host=your-host.aivencloud.com;Port=12345;Database=aegisremit;Username=avnadmin;Password=YOUR_AIVEN_PASSWORD;SslMode=Require;Trust Server Certificate=true

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=${LOCAL_AUTH}

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=${LOCAL_ADMIN}
RABBITMQ_PASSWORD=${LOCAL_AUTH}

# ── MinIO (Object Storage) ────────────────────────────────────────────────
MINIO_ROOT_USER=${LOCAL_ADMIN}
MINIO_ROOT_PASSWORD=${LOCAL_AUTH}

# ── SFTPGo (SFTP Server — Infrastructure) ─────────────────────────────────
# Default admin credentials for first-time setup (change after first login)
SFTPGO_ADMIN_USER=admin
SFTPGO_ADMIN_PASSWORD=${LOCAL_AUTH}
# API key for programmatic access (used by sftp-api in docker-compose.apps.yml)
# Generate after first login: POST /api/v2/apikeys with admin JWT
# See: Remit/get-sftpgo-apikey.ps1
SFTPGO_API_KEY=CHANGE_ME_GENERATE_AFTER_FIRST_LOGIN

# ── Payload encryption (sensitive request body encryption middleware) ─────
# Key must be 32 bytes (AES-256). Generate with: openssl rand -base64 32
# IV must be 16 bytes. Generate with: openssl rand -base64 16
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
ENCRYPTION_IV=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_16
